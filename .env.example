COMPOSE_PROJECT_NAME=rlapp
COMPOSE_PROFILES=backend,frontend

POSTGRES_DB=rlappdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_PORT=5432

BACKEND_PORT=5094
FRONTEND_PORT=3000

ASPNETCORE_ENVIRONMENT=Production
NODE_ENV=production

JWT_SECRET=replace-with-a-long-random-jwt-secret
FRONTEND_SESSION_SECRET=replace-with-a-long-random-session-secret

BACKEND_API_BASE_URL=http://backend:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

MESSAGING_TRANSPORT=InMemory
MESSAGING_ENABLED=false
HEALTHCHECKS_RABBITMQ_ENABLED=false
APPLY_MIGRATIONS_ON_STARTUP=true
